{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "STATE.json v3.1.0",
  "type": "object",
  "required": ["schema_version", "project_id", "step_status", "round_count", "terminal_state", "rework_counts", "loop_counts", "checkpoints", "parallel_block", "pending_dispatches", "history", "metadata"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["3.0.0", "3.1.0"] },
    "project_id": { "type": "string" },
    "step_status": {
      "type": "object",
      "patternProperties": {
        "^STEP[0-9]+$": {
          "type": "object",
          "required": ["role", "status", "dispatch_id"],
          "properties": {
            "role": { "type": "string" },
            "status": { "type": "string", "enum": ["executing", "awaiting_confirmation", "committing"] },
            "dispatch_id": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "round_count": { "type": "integer", "minimum": 0, "maximum": 20, "description": "全局循环轮次计数，用于 DAG 环安全上限" },
    "terminal_state": { "type": ["string", "null"], "enum": ["COMPLETE", "FAILED", "USER_ABORT", "USER_FEEDBACK", "TIMEOUT", null] },
    "rework_counts": {
      "type": "object",
      "patternProperties": { "^STEP[0-9]+$": { "type": "integer", "minimum": 0, "maximum": 3 } },
      "additionalProperties": false
    },
    "loop_counts": {
      "type": "object",
      "patternProperties": { "^STEP[0-9]+$": { "type": "integer", "minimum": 0, "maximum": 10 } },
      "additionalProperties": false
    },
    "checkpoints": {
      "type": "object",
      "patternProperties": {
        "^STEP[0-9]+$": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "created_at": { "type": "string", "format": "date-time" },
            "snapshot": { "type": "object" }
          }
        }
      },
      "additionalProperties": false
    },
    "pending_dispatches": {
      "type": ["array", "null"],
      "description": "v3.1: post_execute/post_confirm 内部调 router 后缓存的下一步 dispatch 指令"
    },
    "parallel_block": {
      "type": ["object", "null"],
      "description": "并行分支块（split_step + join_step + branches）"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "action", "step", "actor", "result"],
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "action": { "type": "string" },
          "step": { "type": "string" },
          "actor": { "type": "string" },
          "result": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "last_advance_at": { "type": "string", "format": "date-time" },
        "user_request": { "type": "string" }
      }
    }
  }
}
