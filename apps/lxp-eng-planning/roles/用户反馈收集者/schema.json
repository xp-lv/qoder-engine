{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "summary"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "backend_fix",
            "design_fix",
            "frontend_fix",
            "no_change"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "required": [
    "result"
  ],
  "_required_files": [
    {
      "name": "迭代需求",
      "path": "outputs/迭代需求.md",
      "type": "deliverable"
    }
  ]
}