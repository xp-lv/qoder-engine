{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "summary"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "approved",
            "rejected"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array"
        },
        "errors": {
          "type": "array"
        }
      }
    }
  },
  "required": [
    "result"
  ],
  "_required_files": [
    {
      "name": "方案审查报告",
      "path": "outputs/方案审查报告.json",
      "type": "process"
    }
  ]
}