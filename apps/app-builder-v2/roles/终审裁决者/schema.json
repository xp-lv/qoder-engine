{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "result": {
      "type": "object",
      "required": ["verdict", "summary"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["confirmed", "consistency_defect", "fail_consistency"]
        },
        "summary": {"type": "string"},
        "findings": {"type": "array"}
      }
    }
  },
  "required": ["result"],
  "_required_files": [
    {
      "name": "终审裁决书",
      "path": "outputs/终审裁决书.json"
    }
  ]
}